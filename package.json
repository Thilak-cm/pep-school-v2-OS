{
  "name": "montessori-os-seed",
  "version": "1.0.0",
  "description": "Seed data uploader for Montessori OS Firestore database",
  "main": "seed.js",
  "scripts": {
    "seed": "node seed.js",
    "start": "node seed.js",
    "upsert:teachers": "node scripts/admin/upsert-hsr-teachers.js",
    "upsert:teachers:push": "node scripts/admin/upsert-hsr-teachers.js --push",
    "upsert:students": "node scripts/admin/upsert-students.js",
    "add:student": "node scripts/admin/add-student.js",
    "cleanup:spokenLanguage": "node scripts/remove_spoken_language.js",
    "cleanup:spokenLanguage:all": "node scripts/remove_spoken_language.js --also-language-code"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.4.0",
    "xlsx": "^0.18.5"
  },
  "keywords": [
    "firebase",
    "firestore",
    "seed",
    "montessori"
  ],
  "author": "Montessori OS Team",
  "license": "MIT"
}

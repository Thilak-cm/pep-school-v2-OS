{
  "name": "montessori-os-seed",
  "version": "1.0.0",
  "description": "Seed data uploader for Montessori OS Firestore database",
  "main": "seed.js",
  "scripts": {
    "deploy": "npx firebase deploy",
    "deploy:functions": "npx firebase deploy --only functions",
    "deploy:hosting": "npx firebase deploy --only hosting",
    "deploy:firestore": "npx firebase deploy --only firestore:rules,firestore:indexes"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.4.0",
    "xlsx": "^0.18.5"
  },
  "keywords": [
    "firebase",
    "firestore",
    "seed",
    "montessori"
  ],
  "author": "Montessori OS Team",
  "license": "MIT",
  "devDependencies": {
    "firebase-tools": "^14.25.0"
  }
}

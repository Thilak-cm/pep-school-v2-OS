{
  "name": "pep-os",
  "version": "1.0.0",
  "description": "Monorepo root for Montessori OS (app, functions, scripts)",
  "type": "module",
  "scripts": {
    "deploy": "npx firebase deploy",
    "deploy:functions": "npx firebase deploy --only functions",
    "deploy:hosting": "npx firebase deploy --only hosting:app",
    "deploy:testbench": "npm --prefix testbench run build && npx firebase deploy --only hosting:testbench",
    "deploy:firestore": "npx firebase deploy --only firestore:rules,firestore:indexes",
    "test:security": "node --test tests/security/*.test.js",
    "test:security:firestore": "node --test tests/security/firestore.rules.test.js",
    "test:security:storage": "node --test tests/security/storage.rules.test.js",
    "export:student-dob-audit": "node scripts/admin/export-dob-audit-csv.js",
    "push-brain": "node scripts/admin/push-brain.mjs"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.4.0",
    "fuse.js": "^6.6.2",
    "googleapis": "^173.0.0",
    "xlsx": "^0.18.5"
  },
  "keywords": [
    "firebase",
    "firestore",
    "seed",
    "montessori"
  ],
  "author": "Montessori OS Team",
  "license": "MIT",
  "devDependencies": {
    "firebase-tools": "^14.25.0"
  }
}

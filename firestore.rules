// Firestore security rules aligned to DATA_STRUCTURE.md (v2)
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function requesterDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isSignedIn() && requesterDoc().data.role == 'superadmin';
    }

    function isClassroomAdmin() {
      return isSignedIn() && requesterDoc().data.role == 'classroomadmin';
    }

    function isPrivilegedAdmin() {
      return isSuperAdmin() || isClassroomAdmin();
    }

    function hasManageableClassroom(classroomId) {
      return isClassroomAdmin() &&
        ('manageableClassrooms' in requesterDoc().data) &&
        (requesterDoc().data.manageableClassrooms is list) &&
        requesterDoc().data.manageableClassrooms.hasAny([classroomId]);
    }

    function managesClassroom(classroomId) {
      return isSuperAdmin() || hasManageableClassroom(classroomId);
    }

    function isTeacher() {
      return isSignedIn() && requesterDoc().data.role == 'teacher';
    }

    function studentClassroomId(studentId) {
      return get(/databases/$(database)/documents/students/$(studentId)).data.classroomId;
    }

    function requiresManageableClassrooms(data) {
      return data.role == 'classroomadmin' &&
        ('manageableClassrooms' in data) &&
        (data.manageableClassrooms is list) &&
        data.manageableClassrooms.size() > 0;
    }

    function isValidAdminPayload(data) {
      return data.role != 'classroomadmin' || requiresManageableClassrooms(data);
    }

    function validLessonNoteConfig(data) {
      // Ensure any dimension arrays present are non-empty lists
      return
        (!('lesson_toddler_dimensions' in data) ||
          ((data.lesson_toddler_dimensions is list) && data.lesson_toddler_dimensions.size() > 0)) &&
        (!('lesson_primary_dimensions' in data) ||
          ((data.lesson_primary_dimensions is list) && data.lesson_primary_dimensions.size() > 0)) &&
        (!('lesson_elementary_dimensions' in data) ||
          ((data.lesson_elementary_dimensions is list) && data.lesson_elementary_dimensions.size() > 0)) &&
        (!('lesson_adolescent_dimensions' in data) ||
          ((data.lesson_adolescent_dimensions is list) && data.lesson_adolescent_dimensions.size() > 0));
    }

    // Users: user can read own profile; admins can read/query all, write any
    match /users/{uid} {
      function isSelf() {
        return isSignedIn() && uid == request.auth.uid;
      }

      allow read: if isSignedIn() && (isSelf() || isPrivilegedAdmin());
      
      allow create: if
        (isSuperAdmin() && isValidAdminPayload(request.resource.data)) ||
        (isClassroomAdmin() && request.resource.data.role == 'teacher') ||
        (isSelf() && request.resource.data.role == 'teacher');
      
      allow update: if
        (isSuperAdmin() && isValidAdminPayload(request.resource.data)) ||
        (isClassroomAdmin() && resource.data.role == 'teacher' && request.resource.data.role == 'teacher') ||
        (isSelf() && resource.data.role == 'teacher' && request.resource.data.role == 'teacher');

      allow delete: if isSuperAdmin() || (isClassroomAdmin() && resource.data.role == 'teacher');
    }

    // Classrooms - simplified security that works
    match /classrooms/{classroomId} {
      // Allow reading individual classroom documents
      allow read: if isPrivilegedAdmin() || isTeacher();
      // Only admins can modify
      allow create, delete: if isSuperAdmin();
      allow update: if
        isSuperAdmin() || (
          isClassroomAdmin() &&
          managesClassroom(classroomId) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['teacherIds', 'updatedAt', 'studentCount']) &&
          (request.resource.data.teacherIds is list) &&
          (request.resource.data.studentCount is int)
        );
    }

    // Classrooms collection queries allowed via read above (no extra collection-level match needed)

    // Students
    match /students/{studentId} {
      function requestClassroomForStudent() {
        return request.resource.data.classroomId;
      }

      function existingClassroomForStudent() {
        return resource.data.classroomId;
      }

      allow read: if isPrivilegedAdmin() || isTeacher();

      allow create: if isSuperAdmin() ||
        (isClassroomAdmin() && managesClassroom(requestClassroomForStudent())); 

      allow update: if isSuperAdmin() || (
        isClassroomAdmin() &&
        managesClassroom(requestClassroomForStudent()) &&
        managesClassroom(existingClassroomForStudent())
      );

      allow delete: if isSuperAdmin() ||
        (isClassroomAdmin() && managesClassroom(existingClassroomForStudent()));

      // Placements subcollection: classroom history per student
      // - Reads: admins and teachers
      // - Writes: admins only (with validation on create/update)
      match /placements/{placementId} {
        function canManagePlacement() {
          return managesClassroom(studentClassroomId(studentId));
        }

        allow read: if isPrivilegedAdmin() || isTeacher();

        // Create validation
        allow create: if canManagePlacement() &&
          request.resource.data.keys().hasAll(['classroomId','startDate']) &&
          (request.resource.data.classroomId is string) &&
          (request.resource.data.startDate is string &&
           request.resource.data.startDate.matches('^\\d{4}-\\d{2}-\\d{2}$')) &&
          (
            // endDate optional; if present, must be a date string
            !('endDate' in request.resource.data) ||
            request.resource.data.endDate == null ||
            (request.resource.data.endDate is string &&
             request.resource.data.endDate.matches('^\\d{4}-\\d{2}-\\d{2}$'))
          ) &&
          (
            // If endDate present, ensure startDate <= endDate (YYYY-MM-DD lexicographic)
            !(request.resource.data.endDate is string) ||
            request.resource.data.startDate <= request.resource.data.endDate
          );

        // Update validation: keep startDate and classroomId immutable; validate endDate shape
        allow update: if canManagePlacement() &&
          request.resource.data.startDate == resource.data.startDate &&
          request.resource.data.classroomId == resource.data.classroomId &&
          (request.resource.data.classroomId is string) &&
          (
            !('endDate' in request.resource.data) ||
            request.resource.data.endDate == null ||
            (request.resource.data.endDate is string &&
             request.resource.data.endDate.matches('^\\d{4}-\\d{2}-\\d{2}$'))
          ) &&
          (
            !(request.resource.data.endDate is string) ||
            request.resource.data.startDate <= request.resource.data.endDate
          );

        // Privileged admins can delete placement docs (e.g., to fix bad backfills)
        allow delete: if canManagePlacement();
      }

      // AI summaries (e.g., baseball card) stored per student
      match /ai_summaries/{summaryId} {
        allow read: if isPrivilegedAdmin() || isTeacher();
        allow create, update, delete: if isSuperAdmin();
      }

      // Chats subcollection - admin only
      match /chats/{chatId} {
        allow read: if isPrivilegedAdmin();
        allow create, update, delete: if isPrivilegedAdmin();
        
        // Messages subcollection within chats
        match /messages/{messageId} {
          allow read: if isPrivilegedAdmin();
          allow create: if isPrivilegedAdmin();
          // Messages are immutable - no updates or deletes allowed
          allow update, delete: if false;
        }
      }

      // Observations subcollection - simplified access
      match /observations/{observationId} {
        function adminCanAccessObservation() {
          return managesClassroom(studentClassroomId(studentId));
        }

        function isMedia(data) {
          return data.type == 'media';
        }

        function validMediaKind(kind) {
          return kind in ['photo', 'video', 'pdf'];
        }

        function expectedContentType(kind) {
          return kind == 'photo'
            ? 'image/webp'
            : (kind == 'pdf' ? 'application/pdf' : 'video/mp4');
        }

        function validMediaEntry(entry, kind) {
          return entry.storagePath is string &&
            entry.storagePath.size() > 0 &&
            entry.contentType is string &&
            entry.contentType == expectedContentType(kind) &&
            entry.sizeBytes is int &&
            entry.sizeBytes >= 0 &&
            (!('width' in entry) || entry.width is int) &&
            (!('height' in entry) || entry.height is int);
        }

        function validMediaCreatePayload(data) {
          return data.keys().hasAll([
              'type',
              'mediaKind',
              'status',
              'media',
              'studentId',
              'classroomId',
              'createdAt',
              'observedAt',
              'createdBy'
            ]) &&
            isMedia(data) &&
            validMediaKind(data.mediaKind) &&
            data.status == 'pending_upload' &&
            (data.media is list) &&
            data.media.size() <= 1 &&
            (
              data.media.size() == 0 ||
              validMediaEntry(data.media[0], data.mediaKind)
            ) &&
            data.studentId == studentId &&
            data.classroomId == studentClassroomId(studentId) &&
            data.createdBy == request.auth.uid &&
            data.createdAt is timestamp &&
            data.observedAt is timestamp;
        }

        function isAllowedNonMediaObservationType(data) {
          return data.type in ['voice', 'lesson'];
        }

        function isAuthor() {
          return resource.data.createdBy == request.auth.uid ||
            resource.data.teacherId == request.auth.uid;
        }

        function withinAuthorActionWindow() {
          return resource.data.createdAt is timestamp &&
            request.time < resource.data.createdAt + duration.value(48, 'h');
        }

        function authorCanEditObservation() {
          return isTeacher() &&
            isAuthor() &&
            withinAuthorActionWindow() &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'text',
              'editCount',
              'updatedAt',
              'lastEditedBy',
              'lastEditedAt',
              'linkedLessonObservationId',
              'linkedObservations',
              'classroomId',
              'lessonTitle',
              'lessonDescription',
              'groupComment',
              'programId',
              'dimensionOrder',
              'groupDefaults',
              'ratings',
              'studentComment',
              'lessonMode'
            ]) &&
            request.resource.data.type == resource.data.type &&
            request.resource.data.createdBy == resource.data.createdBy &&
            request.resource.data.createdAt == resource.data.createdAt &&
            request.resource.data.studentId == resource.data.studentId;
        }

        // Allow reading observations for both admins and teachers
        allow read: if adminCanAccessObservation() || isTeacher();
        
        // Allow creating observations for both admins and teachers
        allow create: if (adminCanAccessObservation() || isTeacher()) &&
          (
            (isMedia(request.resource.data) &&
              validMediaCreatePayload(request.resource.data)) ||
            (!isMedia(request.resource.data) &&
              isAllowedNonMediaObservationType(request.resource.data))
          );
        
        // Updates: admins can update all notes; authors can update their own notes within 48h.
        allow update: if adminCanAccessObservation() || authorCanEditObservation();

        // Allow delete by admins OR by the author within 48h.
        allow delete: if adminCanAccessObservation() || (
          isTeacher() &&
          isAuthor() &&
          withinAuthorActionWindow()
        );
      }

      // Media subcollection - dedicated media docs
      match /media/{mediaId} {
        function adminCanAccessMedia() {
          return managesClassroom(studentClassroomId(studentId));
        }

        function isMedia(data) {
          return data.type == 'media';
        }

        function validMediaKind(kind) {
          return kind in ['photo', 'video', 'pdf'];
        }

        function expectedContentType(kind) {
          return kind == 'photo'
            ? 'image/webp'
            : (kind == 'pdf' ? 'application/pdf' : 'video/mp4');
        }

        function validMediaEntry(entry, kind) {
          return entry.storagePath is string &&
            entry.storagePath.size() > 0 &&
            entry.contentType is string &&
            entry.contentType == expectedContentType(kind) &&
            entry.sizeBytes is int &&
            entry.sizeBytes >= 0 &&
            (!('width' in entry) || entry.width is int) &&
            (!('height' in entry) || entry.height is int);
        }

        function validMediaCreatePayload(data) {
          return data.keys().hasAll([
              'type',
              'mediaKind',
              'status',
              'media',
              'studentId',
              'classroomId',
              'createdAt',
              'observedAt',
              'createdBy'
            ]) &&
            isMedia(data) &&
            validMediaKind(data.mediaKind) &&
            data.status == 'pending_upload' &&
            (data.media is list) &&
            data.media.size() <= 1 &&
            (
              data.media.size() == 0 ||
              validMediaEntry(data.media[0], data.mediaKind)
            ) &&
            data.studentId == studentId &&
            data.classroomId == studentClassroomId(studentId) &&
            data.createdBy == request.auth.uid &&
            data.createdAt is timestamp &&
            data.observedAt is timestamp;
        }

        function isAuthor() {
          return resource.data.createdBy == request.auth.uid ||
            resource.data.teacherId == request.auth.uid;
        }

        function withinAuthorActionWindow() {
          return resource.data.createdAt is timestamp &&
            request.time < resource.data.createdAt + duration.value(48, 'h');
        }

        function authorCanEditMedia() {
          return isTeacher() &&
            isAuthor() &&
            withinAuthorActionWindow() &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'teacherComment',
              'updatedAt',
              'lastEditedBy',
              'lastEditedAt'
            ]) &&
            request.resource.data.type == resource.data.type &&
            request.resource.data.mediaKind == resource.data.mediaKind &&
            request.resource.data.media == resource.data.media &&
            request.resource.data.studentId == resource.data.studentId &&
            request.resource.data.classroomId == resource.data.classroomId &&
            request.resource.data.createdBy == resource.data.createdBy &&
            request.resource.data.createdAt == resource.data.createdAt;
        }

        allow read: if adminCanAccessMedia() || isTeacher();
        allow create: if (adminCanAccessMedia() || isTeacher()) &&
          validMediaCreatePayload(request.resource.data);
        allow update: if adminCanAccessMedia() || authorCanEditMedia();
        allow delete: if adminCanAccessMedia() || (
          isTeacher() && isAuthor() && withinAuthorActionWindow()
        );
      }
    }

    // Collection group rule for media (needed for collectionGroup queries)
    match /{path=**}/media/{mediaId} {
      allow read: if isPrivilegedAdmin() || isTeacher();
    }

    // Collection group rule for ai_summaries (needed for collectionGroup queries)
    match /{path=**}/ai_summaries/{summaryId} {
      allow read: if isPrivilegedAdmin() || isTeacher();
    }

    // Collection group rule for observations (needed for collectionGroup queries)
    match /{path=**}/observations/{observationId} {
      // Allow reading observations for both admins and teachers
      function adminCanQueryObservation() {
        return isSuperAdmin() || (
          (
            ('classroomId' in resource.data) &&
            managesClassroom(resource.data.classroomId)
          ) ||
          (
            ('studentId' in resource.data) &&
            managesClassroom(studentClassroomId(resource.data.studentId))
          )
        );
      }

      allow read: if adminCanQueryObservation() || isTeacher();
    }

    // Feedback collection
    match /feedback/{feedbackId} {
      // Users can read their own feedback
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isPrivilegedAdmin()
      );
      
      // Users can create their own feedback
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid
      );
      
      // Only super admins can update/delete feedback
      allow update, delete: if isSuperAdmin();
    }

    // AI Prompts
    // - Any signed-in user can read (clients fetch prompts at runtime)
    // - Only admins can write
    match /ai_prompts/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    // Programs collection
    // - Any signed-in user can read to support classroom grouping and UI filters
    // - Only super admins (or admin scripts running as them) can write
    match /programs/{programId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    // Branches (center metadata)
    // - Read allowed for signed-in users (used by client UI for branch selection)
    // - Writes restricted to admins (typically performed via admin scripts)
    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    // Config collection
    // - Any signed-in user can read
    // - Only super admins can write
    // - For lessonNote config, enforce non-empty dimension arrays when present
    match /config/{docId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isSuperAdmin() &&
        (
          docId != 'lessonNote' ||
          validLessonNoteConfig(request.resource.data)
        );
    }

    // Temporarily removed default deny to test if it's blocking teacher access
    // match /{document=**} {
    //   allow read, write: if false;
    // }
  }
}

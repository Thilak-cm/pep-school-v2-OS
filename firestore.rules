// Firestore security rules aligned to DATA_STRUCTURE.md (v2)
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Admins only (do not elevate 'other')
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
      return isSignedIn() && request.auth != null;
    }

    // Check if teacher is assigned to a classroom by reading the classroom document
    function classroomHasTeacher(classroomId) {
      return classroomId != null &&
        (get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherIds
          .hasAny([request.auth.uid]));
    }

    function getStudentClassroomId(studentId) {
      return get(/databases/$(database)/documents/students/$(studentId)).data.classroomId;
    }

    // Users: user can read/write own profile; admins can read/write any
    // Avoid recursive self-get by evaluating admin check only when accessing other users' docs
    match /users/{uid} {
      allow read: if isSignedIn() && (uid == request.auth.uid || (uid != request.auth.uid && isAdmin()));
      allow create: if isSignedIn() && (uid == request.auth.uid || (uid != request.auth.uid && isAdmin()));
      allow update: if isSignedIn() && (uid == request.auth.uid || (uid != request.auth.uid && isAdmin()));
      allow delete: if isAdmin();
    }

    // Classrooms - consolidated rule to eliminate conflicts
    match /classrooms/{classroomId} {
      // Temporarily allow everything for testing
      allow read, write, create, update, delete: if true;
    }

    // Collection-level access
    match /classrooms {
      allow read, write, list: if true;
    }

    // Students
    match /students/{studentId} {
      allow read: if isAdmin() || (isTeacher() && classroomHasTeacher(resource.data.classroomId));
      allow create, update, delete: if isAdmin();

      // Observations subcollection
      match /observations/{observationId} {
        // Reads: admin or teacher assigned to the student's classroom
        allow read: if isAdmin() || (isTeacher() && classroomHasTeacher(resource.data.classroomId));

        // Creates: admin or teacher assigned to the student's classroom; enforce field consistency
        allow create: if (
            isAdmin() ||
            (isTeacher() && classroomHasTeacher(getStudentClassroomId(studentId)))
          ) &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.studentId == studentId &&
          request.resource.data.classroomId == getStudentClassroomId(studentId);

        // Updates/Deletes: admin only (teachers cannot edit/delete)
        allow update, delete: if isAdmin() &&
          // Immutable identity/ownership fields
          request.resource.data.studentId == resource.data.studentId &&
          request.resource.data.classroomId == resource.data.classroomId &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.observedAt == resource.data.observedAt;
      }
    }

    // Collection group rule for observations (covers collectionGroup queries)
    match /{path=**}/observations/{observationId} {
      // Reads: admin or teacher assigned via denormalized classroomId on the doc
      allow read: if isAdmin() || (isTeacher() && classroomHasTeacher(resource.data.classroomId));
    }

    // Temporarily removed default deny to test if it's blocking teacher access
    // match /{document=**} {
    //   allow read, write: if false;
    // }
  }
}
// Firestore security rules aligned to DATA_STRUCTURE.md (v2)
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function requesterDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isSignedIn() && requesterDoc().data.role == 'superadmin';
    }

    function isClassroomAdmin() {
      return isSignedIn() && requesterDoc().data.role == 'classroomadmin';
    }

    function isPrivilegedAdmin() {
      return isSuperAdmin() || isClassroomAdmin();
    }

    function hasManageableClassroom(classroomId) {
      return isClassroomAdmin() &&
        ('manageableClassrooms' in requesterDoc().data) &&
        (requesterDoc().data.manageableClassrooms is list) &&
        requesterDoc().data.manageableClassrooms.hasAny([classroomId]);
    }

    function managesClassroom(classroomId) {
      return isSuperAdmin() || hasManageableClassroom(classroomId);
    }

    function isTeacher() {
      return isSignedIn() && requesterDoc().data.role == 'teacher';
    }

    function isTeacherInClassroom(classroomId) {
      return isTeacher() &&
        get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherIds.hasAny([request.auth.uid]);
    }

    function studentClassroomId(studentId) {
      return get(/databases/$(database)/documents/students/$(studentId)).data.classroomId;
    }

    function requiresManageableClassrooms(data) {
      return data.role == 'classroomadmin' &&
        ('manageableClassrooms' in data) &&
        (data.manageableClassrooms is list) &&
        data.manageableClassrooms.size() > 0;
    }

    function isValidAdminPayload(data) {
      return data.role != 'classroomadmin' || requiresManageableClassrooms(data);
    }

    function validLessonNoteConfig(data) {
      // Ensure any dimension arrays present are non-empty lists
      return
        (!('lesson_toddler_dimensions' in data) ||
          ((data.lesson_toddler_dimensions is list) && data.lesson_toddler_dimensions.size() > 0)) &&
        (!('lesson_primary_dimensions' in data) ||
          ((data.lesson_primary_dimensions is list) && data.lesson_primary_dimensions.size() > 0)) &&
        (!('lesson_elementary_dimensions' in data) ||
          ((data.lesson_elementary_dimensions is list) && data.lesson_elementary_dimensions.size() > 0)) &&
        (!('lesson_adolescent_dimensions' in data) ||
          ((data.lesson_adolescent_dimensions is list) && data.lesson_adolescent_dimensions.size() > 0));
    }

    // Users: user can read own profile; admins can read/query all, write any
    match /users/{uid} {
      function isSelf() {
        return isSignedIn() && uid == request.auth.uid;
      }

      allow read: if isSignedIn() && (isSelf() || isPrivilegedAdmin());
      
      allow create: if
        (isSuperAdmin() && isValidAdminPayload(request.resource.data)) ||
        (isClassroomAdmin() && request.resource.data.role == 'teacher');
      
      allow update: if
        // Branch 1: Superadmin can update any user doc
        (isSuperAdmin() && isValidAdminPayload(request.resource.data)) ||
        // Branch 2: Classroomadmin can manage teacher profiles (not their own doc)
        (isClassroomAdmin() && resource.data.role == 'teacher' && request.resource.data.role == 'teacher') ||
        // Branch 3: Self-update — safe fields only, no role change
        (isSelf() && resource.data.role in ['teacher', 'classroomadmin'] &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'displayName', 'photoURL', 'status', 'lastLoginAt', 'updatedAt', 'studentAliases', 'fcmToken', 'notificationPreferences'
          ]));

      allow delete: if isSuperAdmin() || (isClassroomAdmin() && resource.data.role == 'teacher');
    }

    // Superadmin-only digest — explicit match prevents classroomadmin access via wildcard
    match /classrooms/_digest_all/digests/{digestId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }
    match /classrooms/_digest_all/digests/{digestId}/history/{weekKey} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // Classrooms - role-scoped reads
    match /classrooms/{classroomId} {
      // Individual doc reads: teachers scoped to assigned classrooms
      allow get: if isPrivilegedAdmin() || (isTeacher() && resource.data.teacherIds.hasAny([request.auth.uid]));
      // List queries: teachers allowed (client filters by teacherIds; resource.data unavailable on list)
      allow list: if isPrivilegedAdmin() || isTeacher();
      // Only admins can modify
      allow create, delete: if isSuperAdmin();
      allow update: if
        isSuperAdmin() || (
          isClassroomAdmin() &&
          managesClassroom(classroomId) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['teacherIds', 'updatedAt', 'studentCount', 'deletedStudentCount']) &&
          (request.resource.data.teacherIds is list) &&
          (request.resource.data.studentCount is int) &&
          (!('deletedStudentCount' in request.resource.data) || request.resource.data.deletedStudentCount is int)
        );

      // Weekly digest (PEP-297) — CF writes via admin SDK; admins can read
      match /digests/{digestId} {
        allow read: if managesClassroom(classroomId);
        allow write: if false;

        match /history/{weekKey} {
          allow read: if managesClassroom(classroomId);
          allow write: if false;
        }
      }
    }

    // Classrooms collection queries allowed via read above (no extra collection-level match needed)

    // Students — reads scoped by role
    match /students/{studentId} {
      function requestClassroomForStudent() {
        return request.resource.data.classroomId;
      }

      function existingClassroomForStudent() {
        return resource.data.classroomId;
      }

      // Individual doc reads: scoped per role
      // resource == null handles tx.get() on not-yet-created docs (ID uniqueness check)
      allow get: if isSuperAdmin() ||
        (isClassroomAdmin() && (resource == null || managesClassroom(resource.data.classroomId))) ||
        isTeacherInClassroom(resource.data.classroomId);
      // List queries: teachers allowed (client scopes via classroomId; resource.data unavailable on list)
      allow list: if isPrivilegedAdmin() || isTeacher();

      allow create: if isSuperAdmin() ||
        (isClassroomAdmin() && managesClassroom(requestClassroomForStudent())); 

      allow update: if isSuperAdmin() || (
        isClassroomAdmin() &&
        managesClassroom(requestClassroomForStudent()) &&
        managesClassroom(existingClassroomForStudent())
      );

      allow delete: if isSuperAdmin() ||
        (isClassroomAdmin() && managesClassroom(existingClassroomForStudent()));

      // Placements subcollection: classroom history per student
      // - Reads: scoped by role
      // - Writes: admins only (with validation on create/update)
      match /placements/{placementId} {
        function canManagePlacement() {
          return managesClassroom(studentClassroomId(studentId));
        }

        allow read: if isSuperAdmin() ||
          (isClassroomAdmin() && managesClassroom(studentClassroomId(studentId))) ||
          isTeacherInClassroom(studentClassroomId(studentId));

        // Create validation
        // Use request.resource.data.classroomId (not parent doc lookup) so placement
        // can be created in the same transaction that creates the student doc.
        allow create: if managesClassroom(request.resource.data.classroomId) &&
          request.resource.data.keys().hasAll(['classroomId','startDate']) &&
          (request.resource.data.classroomId is string) &&
          (request.resource.data.startDate is string &&
           request.resource.data.startDate.matches('^\\d{4}-\\d{2}-\\d{2}$')) &&
          (
            // endDate optional; if present, must be a date string
            !('endDate' in request.resource.data) ||
            request.resource.data.endDate == null ||
            (request.resource.data.endDate is string &&
             request.resource.data.endDate.matches('^\\d{4}-\\d{2}-\\d{2}$'))
          ) &&
          (
            // If endDate present, ensure startDate <= endDate (YYYY-MM-DD lexicographic)
            !(request.resource.data.endDate is string) ||
            request.resource.data.startDate <= request.resource.data.endDate
          );

        // Update validation: keep startDate and classroomId immutable; validate endDate shape
        allow update: if canManagePlacement() &&
          request.resource.data.startDate == resource.data.startDate &&
          request.resource.data.classroomId == resource.data.classroomId &&
          (request.resource.data.classroomId is string) &&
          (
            !('endDate' in request.resource.data) ||
            request.resource.data.endDate == null ||
            (request.resource.data.endDate is string &&
             request.resource.data.endDate.matches('^\\d{4}-\\d{2}-\\d{2}$'))
          ) &&
          (
            !(request.resource.data.endDate is string) ||
            request.resource.data.startDate <= request.resource.data.endDate
          );

        // Privileged admins can delete placement docs (e.g., to fix bad backfills)
        allow delete: if canManagePlacement();
      }

      // AI summaries (baseball card, reports, signals, soul, guidelines) stored per student
      match /ai_summaries/{summaryId} {
        allow read: if isPrivilegedAdmin() || isTeacherInClassroom(studentClassroomId(studentId));
        allow create, update, delete: if isSuperAdmin();

        // Version history for soul and guidelines (PEP-149)
        // Cloud Functions write via admin SDK; superadmin for manual review
        match /history/{historyId} {
          allow read: if isSuperAdmin();
          allow create, update, delete: if isSuperAdmin();
        }

        // Plan feedback (PEP-282) — any authenticated user can read/write
        match /monthly_plan_feedback/{feedbackId} {
          allow read, create: if request.auth != null;
        }
      }

      // Interview transcripts — append-only, Cloud Functions write via admin SDK
      // Teachers and admins can read; no client-side writes
      match /interviews/{interviewId} {
        allow read: if isPrivilegedAdmin() || isTeacherInClassroom(studentClassroomId(studentId));
        allow create, update, delete: if false;
      }

      // Chats subcollection — scoped by role
      match /chats/{chatId} {
        allow read: if isPrivilegedAdmin() || isTeacherInClassroom(studentClassroomId(studentId));
        allow create: if (isPrivilegedAdmin() || isTeacherInClassroom(studentClassroomId(studentId))) &&
          request.resource.data.createdBy == request.auth.uid;
        allow update: if (isPrivilegedAdmin() || isTeacherInClassroom(studentClassroomId(studentId))) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name', 'updatedAt', 'lastMessagePreview', 'messageCount', 'deleted'
          ]);
        allow delete: if isPrivilegedAdmin();

        // Messages subcollection within chats
        match /messages/{messageId} {
          allow read: if isPrivilegedAdmin() || isTeacherInClassroom(studentClassroomId(studentId));
          allow create: if (isPrivilegedAdmin() || isTeacherInClassroom(studentClassroomId(studentId))) &&
            request.resource.data.role is string &&
            request.resource.data.content is string;
          // Messages are immutable except for cancelledResponseAt (stop button)
          allow update: if (isPrivilegedAdmin() || isTeacherInClassroom(studentClassroomId(studentId)))
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cancelledResponseAt']);
          allow delete: if false;
        }
      }

      // Observations subcollection - simplified access
      match /observations/{observationId} {
        function adminCanAccessObservation() {
          return managesClassroom(studentClassroomId(studentId));
        }

        function isMedia(data) {
          return data.type == 'media';
        }

        function validMediaKind(kind) {
          return kind in ['photo', 'video', 'pdf'];
        }

        function expectedContentType(kind) {
          return kind == 'photo'
            ? 'image/webp'
            : (kind == 'pdf' ? 'application/pdf' : 'video/mp4');
        }

        function validMediaEntry(entry, kind) {
          return entry.storagePath is string &&
            entry.storagePath.size() > 0 &&
            entry.contentType is string &&
            entry.contentType == expectedContentType(kind) &&
            entry.sizeBytes is int &&
            entry.sizeBytes >= 0 &&
            (!('width' in entry) || entry.width is int) &&
            (!('height' in entry) || entry.height is int);
        }

        function validMediaCreatePayload(data) {
          return data.keys().hasAll([
              'type',
              'mediaKind',
              'status',
              'media',
              'studentId',
              'classroomId',
              'createdAt',
              'observedAt',
              'createdBy'
            ]) &&
            isMedia(data) &&
            validMediaKind(data.mediaKind) &&
            data.status == 'pending_upload' && // observations path: only pending_upload (media path allows 'ready' too for reassignment)
            (data.media is list) &&
            data.media.size() <= 1 &&
            (
              data.media.size() == 0 ||
              validMediaEntry(data.media[0], data.mediaKind)
            ) &&
            data.studentId == studentId &&
            data.classroomId == studentClassroomId(studentId) &&
            data.createdBy == request.auth.uid &&
            data.createdAt is timestamp &&
            data.observedAt is timestamp;
        }

        function isAllowedNonMediaObservationType(data) {
          return data.type in ['text', 'voice', 'lesson'] &&
            data.studentId == studentId &&
            data.classroomId == studentClassroomId(studentId) &&
            data.createdBy == request.auth.uid &&
            data.createdAt is timestamp;
        }

        function isAuthor() {
          return resource.data.createdBy == request.auth.uid ||
            resource.data.teacherId == request.auth.uid;
        }

        function withinAuthorActionWindow() {
          return resource.data.createdAt is timestamp &&
            request.time < resource.data.createdAt + duration.value(48, 'h');
        }

        function authorCanEditObservation() {
          return isTeacher() &&
            isAuthor() &&
            withinAuthorActionWindow() &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'text',
              'editCount',
              'updatedAt',
              'lastEditedBy',
              'lastEditedAt',
              'linkedLessonObservationId',
              'linkedObservations',
              'classroomId',
              'lessonTitle',
              'lessonDescription',
              'groupComment',
              'programId',
              'dimensionOrder',
              'groupDefaults',
              'ratings',
              'studentComment',
              'lessonMode'
            ]) &&
            request.resource.data.type == resource.data.type &&
            request.resource.data.createdBy == resource.data.createdBy &&
            request.resource.data.createdAt == resource.data.createdAt &&
            request.resource.data.studentId == resource.data.studentId;
        }

        // Allow reading observations — scoped by role
        allow read: if adminCanAccessObservation() || isTeacherInClassroom(studentClassroomId(studentId));
        
        // Allow creating observations — scoped by role
        allow create: if (adminCanAccessObservation() || isTeacherInClassroom(studentClassroomId(studentId))) &&
          (
            (isMedia(request.resource.data) &&
              validMediaCreatePayload(request.resource.data)) ||
            (!isMedia(request.resource.data) &&
              isAllowedNonMediaObservationType(request.resource.data))
          );
        
        // Updates: admins can update all notes; authors can update their own notes within 48h.
        allow update: if adminCanAccessObservation() || authorCanEditObservation();

        // Allow delete by admins OR by the author within 48h.
        allow delete: if adminCanAccessObservation() || (
          isTeacher() &&
          isAuthor() &&
          withinAuthorActionWindow()
        );
      }

      // Media subcollection - dedicated media docs
      match /media/{mediaId} {
        function adminCanAccessMedia() {
          return managesClassroom(studentClassroomId(studentId));
        }

        function isMedia(data) {
          return data.type == 'media';
        }

        function validMediaKind(kind) {
          return kind in ['photo', 'video', 'pdf'];
        }

        function expectedContentType(kind) {
          return kind == 'photo'
            ? 'image/webp'
            : (kind == 'pdf' ? 'application/pdf' : 'video/mp4');
        }

        function validMediaEntry(entry, kind) {
          return entry.storagePath is string &&
            entry.storagePath.size() > 0 &&
            entry.contentType is string &&
            entry.contentType == expectedContentType(kind) &&
            entry.sizeBytes is int &&
            entry.sizeBytes >= 0 &&
            (!('width' in entry) || entry.width is int) &&
            (!('height' in entry) || entry.height is int);
        }

        function validMediaCreatePayload(data) {
          return data.keys().hasAll([
              'type',
              'mediaKind',
              'status',
              'media',
              'studentId',
              'classroomId',
              'createdAt',
              'observedAt',
              'createdBy'
            ]) &&
            isMedia(data) &&
            validMediaKind(data.mediaKind) &&
            data.status in ['pending_upload', 'ready'] &&
            (data.media is list) &&
            data.media.size() <= 1 &&
            (
              data.media.size() == 0 ||
              validMediaEntry(data.media[0], data.mediaKind)
            ) &&
            data.studentId == studentId &&
            data.classroomId == studentClassroomId(studentId) &&
            data.createdBy == request.auth.uid &&
            data.createdAt is timestamp &&
            data.observedAt is timestamp;
        }

        function isAuthor() {
          return resource.data.createdBy == request.auth.uid ||
            resource.data.teacherId == request.auth.uid;
        }

        function withinAuthorActionWindow() {
          return resource.data.createdAt is timestamp &&
            request.time < resource.data.createdAt + duration.value(48, 'h');
        }

        function authorCanEditMedia() {
          return isTeacher() &&
            isAuthor() &&
            withinAuthorActionWindow() &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'teacherComment',
              'updatedAt',
              'lastEditedBy',
              'lastEditedAt'
            ]) &&
            request.resource.data.type == resource.data.type &&
            request.resource.data.mediaKind == resource.data.mediaKind &&
            request.resource.data.media == resource.data.media &&
            request.resource.data.studentId == resource.data.studentId &&
            request.resource.data.classroomId == resource.data.classroomId &&
            request.resource.data.createdBy == resource.data.createdBy &&
            request.resource.data.createdAt == resource.data.createdAt;
        }

        allow read: if adminCanAccessMedia() || isTeacherInClassroom(studentClassroomId(studentId));
        allow create: if (adminCanAccessMedia() || isTeacherInClassroom(studentClassroomId(studentId))) &&
          validMediaCreatePayload(request.resource.data);
        allow update: if adminCanAccessMedia() || authorCanEditMedia();
        allow delete: if adminCanAccessMedia() || (
          isTeacher() && isAuthor() && withinAuthorActionWindow()
        );
      }
    }

    // Collection group rule for media (needed for collectionGroup queries)
    match /{path=**}/media/{mediaId} {
      allow read: if isPrivilegedAdmin() ||
        (isTeacher() && ('studentId' in resource.data) && isTeacherInClassroom(studentClassroomId(resource.data.studentId))) ||
        (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    // Collection group rule for ai_summaries (needed for collectionGroup queries)
    match /{path=**}/ai_summaries/{summaryId} {
      allow read: if isPrivilegedAdmin() ||
        (isTeacher() && ('classroomId' in resource.data) && isTeacherInClassroom(resource.data.classroomId));
    }

    // Collection group rule for observations (needed for collectionGroup queries)
    match /{path=**}/observations/{observationId} {
      // Allow reading observations for both admins and teachers
      function adminCanQueryObservation() {
        return (
          ('classroomId' in resource.data) &&
          managesClassroom(resource.data.classroomId)
        ) || (
          ('studentId' in resource.data) &&
          managesClassroom(studentClassroomId(resource.data.studentId))
        );
      }

      allow read: if isSuperAdmin() ||
        adminCanQueryObservation() ||
        (isTeacher() && ('studentId' in resource.data) && isTeacherInClassroom(studentClassroomId(resource.data.studentId))) ||
        (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    // Feedback collection
    match /feedback/{feedbackId} {
      // Users can read their own feedback
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isPrivilegedAdmin()
      );
      
      // Users can create their own feedback
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid
      );
      
      // Only super admins can update/delete feedback
      allow update, delete: if isSuperAdmin();
    }

    // Programs collection
    // - Any signed-in user can read to support classroom grouping and UI filters
    // - Only super admins (or admin scripts running as them) can write
    match /programs/{programId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    // Branches (center metadata)
    // - Read allowed for signed-in users (used by client UI for branch selection)
    // - Writes restricted to admins (typically performed via admin scripts)
    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    // Config collection
    // - Any signed-in user can read
    // - Only super admins can write
    // - For lessonNote config, enforce non-empty dimension arrays when present
    match /config/{docId} {
      allow read: if isSignedIn();

      allow create, update, delete: if isSuperAdmin() &&
        (
          docId != 'lessonNote' ||
          validLessonNoteConfig(request.resource.data)
        );
    }

    // Testbench — nested under testbench/settings anchor doc
    // Settings doc: superadmins read/write
    match /testbench/settings {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();

      // Access control — per-teacher feature grants (PEP-224)
      // - Superadmins can read/write any access doc
      // - Teachers can read their own access doc (to know their allowed features)
      match /access/{uid} {
        allow read: if isSuperAdmin() || (isSignedIn() && request.auth.uid == uid);
        allow create, update: if isSuperAdmin();
        allow delete: if isSuperAdmin();
      }

      // Run results — prompt test bench run history
      // - Superadmins have full read/create access
      // - Teachers with access grants can read/create runs for their allowed features (PEP-224)
      // - Updates restricted to sessionName field only (PEP-211)
      match /runs/{runId} {
        allow read: if isSuperAdmin()
          || (isSignedIn()
              && requesterDoc().data.role in ['teacher', 'classroomadmin']
              && exists(/databases/$(database)/documents/testbench/settings/access/$(request.auth.uid))
              && resource.data.feature in get(/databases/$(database)/documents/testbench/settings/access/$(request.auth.uid)).data.allowedFeatures);
        allow create: if isSuperAdmin()
          || (isSignedIn()
              && requesterDoc().data.role in ['teacher', 'classroomadmin']
              && exists(/databases/$(database)/documents/testbench/settings/access/$(request.auth.uid))
              && request.resource.data.feature in get(/databases/$(database)/documents/testbench/settings/access/$(request.auth.uid)).data.allowedFeatures);
        allow update: if (isSuperAdmin()
              || (isSignedIn()
                  && requesterDoc().data.role in ['teacher', 'classroomadmin']
                  && exists(/databases/$(database)/documents/testbench/settings/access/$(request.auth.uid))
                  && resource.data.feature in get(/databases/$(database)/documents/testbench/settings/access/$(request.auth.uid)).data.allowedFeatures))
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sessionName'])
          && (!('sessionName' in request.resource.data) || request.resource.data.sessionName is string);
        allow delete: if false;
      }
    }

    // Alerts bus (PEP-296) — alert docs for Dynamic Island pill + Alerts page
    // CFs create via admin SDK (bypasses rules); superadmins create via frontend (broadcasts)
    // All signed-in users can read; update restricted to dismissedBy field only
    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin();
      allow update: if (isSuperAdmin() && resource.data.type == 'broadcast')
        || (isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissedBy', 'responses'])
          && (
            // dismissedBy-only arm (ack broadcasts)
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissedBy'])
              && request.resource.data.dismissedBy is map
              && resource.data.dismissedBy is map
              && request.resource.data.dismissedBy.diff(resource.data.dismissedBy).affectedKeys().hasOnly([request.auth.uid]))
            // dismissedBy + responses arm (poll vote — atomic write)
            || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissedBy', 'responses'])
              && request.resource.data.dismissedBy is map
              && resource.data.dismissedBy is map
              && request.resource.data.dismissedBy.diff(resource.data.dismissedBy).affectedKeys().hasOnly([request.auth.uid])
              && request.resource.data.responses is map
              && request.resource.data.responses.diff(resource.data.get('responses', {})).affectedKeys().hasOnly([request.auth.uid])
              && !(request.auth.uid in resource.data.get('responses', {})))
          ));
      allow delete: if isSuperAdmin();
    }

    // Stats cache (PEP-285) — pre-computed per-classroom stats written by CF
    // Client reads scoped by role; writes only via admin SDK (Cloud Functions)
    match /statsCache/{docId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        docId == '_meta' ||
        (resource.data.classroomId != null &&
          (managesClassroom(resource.data.classroomId) ||
           isTeacherInClassroom(resource.data.classroomId)))
      );
      allow write: if false;
    }

    // Default deny — any collection not explicitly matched above is blocked
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

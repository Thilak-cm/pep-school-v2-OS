// Firestore security rules aligned to DATA_STRUCTURE.md (v2)
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Admins only (do not elevate 'other')
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    // Users: user can read/write own profile; admins can read/write any
    // Avoid recursive self-get by evaluating admin check only when accessing other users' docs
    match /users/{uid} {
      allow read: if isSignedIn() && (uid == request.auth.uid || (uid != request.auth.uid && isAdmin()));
      
      // Create: basic validation (email uniqueness will be enforced by Cloud Functions)
      allow create: if isSignedIn() && 
        (uid == request.auth.uid || (uid != request.auth.uid && isAdmin()));
      
      // Update: basic validation (email uniqueness will be enforced by Cloud Functions)
      allow update: if isSignedIn() && 
        (uid == request.auth.uid || (uid != request.auth.uid && isAdmin()));
      
      allow delete: if isAdmin();
    }

    // Collection-level access for listing users (needed for admin queries)
    match /users {
      // Allow listing for admins only
      allow list: if isAdmin();
    }

    // Classrooms - simplified security that works
    match /classrooms/{classroomId} {
      // Allow reading individual classroom documents
      allow read: if isAdmin() || isTeacher();
      // Only admins can modify
      allow create, update, delete: if isAdmin();
    }

    // Collection-level access for listing
    match /classrooms {
      // Allow listing for both admins and teachers
      allow list: if isAdmin() || isTeacher();
    }

    // Students
    match /students/{studentId} {
      allow read: if isAdmin() || isTeacher();
      allow create, update, delete: if isAdmin();

      // Observations subcollection - simplified access
      match /observations/{observationId} {
        // Allow reading observations for both admins and teachers
        allow read: if isAdmin() || isTeacher();
        
        // Allow creating observations for both admins and teachers
        allow create: if isAdmin() || isTeacher();
        
        // Updates: allow admins, or allow creators to update limited metadata fields
        allow update: if isAdmin() || (
          isTeacher() &&
          (
            // Author-only updates with restricted field changes
            resource.data.createdBy == request.auth.uid ||
            resource.data.teacherId == request.auth.uid
          ) &&
          // Only allow non-destructive metadata changes (e.g., edit metadata)
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'updatedAt',
            'lastEditedBy',
            'lastEditedAt'
          ])
        );

        // Allow delete by admins OR by the author (to enable reassign by author)
        allow delete: if isAdmin() || (
          isTeacher() && (
            // Support both current 'createdBy' and legacy 'teacherId'
            resource.data.createdBy == request.auth.uid ||
            resource.data.teacherId == request.auth.uid
          )
        );
      }
    }

    // Collection group rule for observations (needed for collectionGroup queries)
    match /{path=**}/observations/{observationId} {
      // Allow reading observations for both admins and teachers
      allow read: if isAdmin() || isTeacher();
    }

    // Feedback collection
    match /feedback/{feedbackId} {
      // Users can read their own feedback
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      
      // Users can create their own feedback
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid
      );
      
      // Only admins can update/delete feedback
      allow update, delete: if isAdmin();
    }

    // Temporarily removed default deny to test if it's blocking teacher access
    // match /{document=**} {
    //   allow read, write: if false;
    // }
  }
}

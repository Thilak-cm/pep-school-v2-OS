rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function requesterDoc() {
      return isSignedIn()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
        : null;
    }

    function mediaDoc(studentId, mediaId) {
      return firestore.get(
        /databases/(default)/documents/students/$(studentId)/media/$(mediaId)
      );
    }

    function isMediaDoc(doc) {
      return doc.data != null && doc.data.type == 'media';
    }

    function isAuthor(doc) {
      return doc.data.createdBy == request.auth.uid ||
        doc.data.teacherId == request.auth.uid;
    }

    function withinDeleteWindow(doc) {
      return doc.data.createdAt is timestamp &&
        request.time < doc.data.createdAt + duration.value(48, 'h');
    }

    function allowedContent(mediaKind, fileName, contentType) {
      return (mediaKind == 'photo' &&
          fileName.matches('.*\\.webp$') &&
          contentType == 'image/webp') ||
        (mediaKind == 'pdf' &&
          fileName.matches('.*\\.pdf$') &&
          contentType == 'application/pdf') ||
        (mediaKind == 'video' &&
          fileName.matches('.*\\.mp4$') &&
          contentType == 'video/mp4');
    }

    function sizeAllowed(mediaKind, bytes) {
      return mediaKind != 'photo' || bytes <= 2 * 1024 * 1024;
    }

    // Role gate for media access — only 2 firestore.get() paths
    // (requesterDoc + mediaDoc).
    //
    // Classroom-level scoping for classroomadmins is enforced by
    // Firestore rules when the media doc is created (the doc can
    // only reach status 'pending_upload' if managesClassroom
    // passed). Storage rules trust that Firestore-side gate and
    // avoid a third cross-service lookup (studentClassroomId) that
    // pushed classroomadmin evaluations over the Storage rules'
    // firestore.get() budget, causing blanket 403s.
    function isKnownRole() {
      return requesterDoc().data.role in ['teacher', 'superadmin', 'classroomadmin'];
    }

    match /students/{studentId}/media/{mediaId}/{fileName} {
      allow read: if isSignedIn() &&
        isMediaDoc(mediaDoc(studentId, mediaId)) &&
        isKnownRole();

      allow create, update: if isSignedIn() &&
        isMediaDoc(mediaDoc(studentId, mediaId)) &&
        isKnownRole() &&
        mediaDoc(studentId, mediaId).data.status == 'pending_upload' &&
        allowedContent(
          mediaDoc(studentId, mediaId).data.mediaKind,
          fileName,
          request.resource.contentType
        ) &&
        sizeAllowed(mediaDoc(studentId, mediaId).data.mediaKind, request.resource.size);

      allow delete: if isSignedIn() &&
        isMediaDoc(mediaDoc(studentId, mediaId)) &&
        (
          requesterDoc().data.role in ['superadmin', 'classroomadmin'] ||
          (requesterDoc().data.role == 'teacher' &&
           isAuthor(mediaDoc(studentId, mediaId)) &&
           withinDeleteWindow(mediaDoc(studentId, mediaId)))
        );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

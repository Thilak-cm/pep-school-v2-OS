rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function requesterDoc() {
      return isSignedIn()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
        : null;
    }

    function isSuperAdmin() {
      return isSignedIn() && requesterDoc().data.role == 'superadmin';
    }

    function isClassroomAdmin() {
      return isSignedIn() && requesterDoc().data.role == 'classroomadmin';
    }

    function isTeacher() {
      return isSignedIn() && requesterDoc().data.role == 'teacher';
    }

    function hasManageableClassroom(classroomId) {
      return isClassroomAdmin() &&
        ('manageableClassrooms' in requesterDoc().data) &&
        (requesterDoc().data.manageableClassrooms is list) &&
        requesterDoc().data.manageableClassrooms.hasAny([classroomId]);
    }

    function managesClassroom(classroomId) {
      return isSuperAdmin() || hasManageableClassroom(classroomId);
    }

    function studentClassroomId(studentId) {
      return firestore.get(/databases/(default)/documents/students/$(studentId)).data.classroomId;
    }

    function mediaDoc(studentId, observationId) {
      return firestore.get(
        /databases/(default)/documents/students/$(studentId)/observations/$(observationId)
      );
    }

    function isMediaDoc(doc) {
      return doc.data != null && doc.data.type == 'media';
    }

    function isAuthor(doc) {
      return doc.data.createdBy == request.auth.uid ||
        doc.data.teacherId == request.auth.uid;
    }

    function withinDeleteWindow(doc) {
      return doc.data.createdAt is timestamp &&
        request.time < doc.data.createdAt + duration.value(24, 'h');
    }

    function allowedContent(mediaKind, fileName, contentType) {
      return (mediaKind == 'photo' &&
          fileName.matches('.*\\.webp$') &&
          contentType == 'image/webp') ||
        (mediaKind == 'pdf' &&
          fileName.matches('.*\\.pdf$') &&
          contentType == 'application/pdf') ||
        (mediaKind == 'video' &&
          fileName.matches('.*\\.mp4$') &&
          contentType == 'video/mp4');
    }

    function sizeAllowed(mediaKind, bytes) {
      return mediaKind != 'photo' || bytes <= 2 * 1024 * 1024;
    }

    function canAccessMedia(studentId) {
      // Teachers can access media they can see; admins must manage the classroom
      return isTeacher() || managesClassroom(studentClassroomId(studentId));
    }

    match /students/{studentId}/observations/{observationId}/media/{fileName} {
      allow read: if isSignedIn() &&
        isMediaDoc(mediaDoc(studentId, observationId)) &&
        canAccessMedia(studentId);

      allow create, update: if isSignedIn() &&
        isMediaDoc(mediaDoc(studentId, observationId)) &&
        canAccessMedia(studentId) &&
        mediaDoc(studentId, observationId).data.status == 'pending_upload' &&
        allowedContent(
          mediaDoc(studentId, observationId).data.mediaKind,
          fileName,
          request.resource.contentType
        ) &&
        sizeAllowed(mediaDoc(studentId, observationId).data.mediaKind, request.resource.size);

      allow delete: if isSignedIn() &&
        isMediaDoc(mediaDoc(studentId, observationId)) &&
        (
          isSuperAdmin() ||
          managesClassroom(studentClassroomId(studentId)) ||
          (isTeacher() && isAuthor(mediaDoc(studentId, observationId)) && withinDeleteWindow(mediaDoc(studentId, observationId)))
        );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

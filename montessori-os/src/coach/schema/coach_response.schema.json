{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coach_response.schema.json",
  "type": "object",
  "required": ["nudges"],
  "additionalProperties": false,
  "properties": {
    "nudges": {
      "type": "array",
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "reason", "confidence"],
        "properties": {
          "id": { "type": "string", "enum": ["duration", "modality", "independence", "evidence", "subjective"] },
          "reason": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
